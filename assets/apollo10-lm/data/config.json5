  "events": {
    "time_scale": "UTC",
    "closestApproach": {
      "startTime": "1969-05-22T21:30:43Z",
      "durationSeconds": 0,
      "label": "Closest Approach (14.4 km)",
      "burnFlag": false,
      "infoText": "Snoopy descended to just 14.4 km (47,400 ft) above the lunar surface - the point where powered descent would begin for an actual landing. This was the dress rehearsal for Apollo 11.",
      "body": "SC"
    },
    "descentStageJettison": {
      "startTime": "1969-05-22T21:44:00Z",
      "durationSeconds": 0,
      "label": "Descent Stage Jettison",
      "burnFlag": false,
      "infoText": "Snoopy jettisoned its descent stage at 58.2 km altitude. The ascent stage then fired to return to lunar orbit for rendezvous with Charlie Brown (CSM).",
      "body": "SC"
    },
    "trackingStart": {
      "startTime": "1969-05-23T05:38:00Z",
      "durationSeconds": 0,
      "label": "Snoopy Tracking Begins",
      "burnFlag": false,
      "infoText": "Start of reconstructed Snoopy trajectory data. Snoopy was jettisoned from Charlie Brown CSM 25 minutes earlier at 05:13 UTC, and is now departing lunar orbit on its way to heliocentric orbit.",
      "body": "SC"
    },
    "crewTransfer": {
      "startTime": "1969-05-23T03:25:00Z",
      "durationSeconds": 0,
      "label": "Crew Returns to CSM",
      "burnFlag": false,
      "infoText": "Stafford and Cernan transferred back to Command Module 'Charlie Brown' after the successful lunar descent rehearsal.",
      "body": "SC"
    },
    "lmJettison": {
      "startTime": "1969-05-23T05:13:00Z",
      "durationSeconds": 0,
      "label": "Snoopy Jettisoned",
      "burnFlag": false,
      "infoText": "The LM ascent stage 'Snoopy' was jettisoned from the CSM. Remaining propellant was burned to send it into heliocentric orbit - where it remains to this day.",
      "body": "SC"
    },
    "dataEnd": {
      "startTime": "1969-05-28T00:06:00Z",
      "durationSeconds": 0,
      "label": "Snoopy Departs Forever",
      "burnFlag": false,
      "infoText": "End of reconstructed trajectory data. Snoopy continues on its heliocentric orbit around the Sun - where it remains to this day, the only Apollo Lunar Module still in space.",
      "body": "SC"
    }
  },

