      "startTime": "1969-07-20T20:17:40Z",
      "durationSeconds": 0,
      "label": "Eagle Lands (Context)",
      "burnFlag": false,
      "infoText": "While the S-IVB continues outward into heliocentric space, Eagle lands in the Sea of Tranquility. The S-IVB is now approximately 200,000 km from the Moon.",
      "body": "SC"
    },
    "dataEnd": {
      "startTime": "1969-07-28T00:06:00Z",
      "durationSeconds": 0,
      "label": "S-IVB Enters Solar Orbit",
      "burnFlag": false,
      "infoText": "End of reconstructed trajectory data. The S-IVB continues into permanent heliocentric orbit around the Sun, where it remains to this day - one of humanity's earliest artifacts in interplanetary space.",
      "body": "SC"
    }
  },

  "eventConfigs": {
