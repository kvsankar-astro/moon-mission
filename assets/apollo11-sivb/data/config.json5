      "startTime": "1969-07-17T16:40:00Z",
      "durationSeconds": 0,
      "label": "S-IVB Tracking Begins",
      "burnFlag": false,
      "infoText": "Start of reconstructed S-IVB trajectory data. The spent third stage separated from Columbia/Eagle on July 16 at 17:49 UTC and is now coasting toward the Moon on a flyby trajectory.",
