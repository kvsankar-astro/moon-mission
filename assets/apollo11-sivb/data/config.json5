    "lunarFlyby": {
      "startTime": "1969-07-19T20:00:00Z",
      "durationSeconds": 0,
      "label": "Lunar Flyby",
      "burnFlag": false,
      "infoText": "The S-IVB passes behind the Moon's trailing edge, receiving a gravity assist that accelerates it beyond Earth escape velocity. Meanwhile, Columbia entered lunar orbit ~3 hours earlier.",
      "body": "SC"
