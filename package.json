{
  "name": "chandrayaan3-animation",
  "version": "1.0.0",
  "description": "3D animation of the ISRO Chandrayaan 3 mission orbit",
  "type": "module",
  "main": "chandrayaan3.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite --port 7274",
    "mcp-server": "playwright mcp",
    "typecheck": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest test/ui.test.js",
    "test:verbose": "vitest test/ui.test.js --reporter=verbose",
    "test:unit": "vitest run --exclude=test/ui.test.js --exclude=test/mission-smoke.test.js --exclude=test/production-mission-smoke.test.js --exclude=test/index-landing-compare-smoke.test.js",
    "test:unit:coverage": "npm run test:unit -- --coverage",
    "configs:bootstrap": "node scripts/bootstrap-mission-config-json5.mjs",
    "configs:compile": "node scripts/compile-mission-configs.mjs",
    "configs:check": "node scripts/compile-mission-configs.mjs --check",
    "configs:lint": "node scripts/compile-mission-configs.mjs --check --lint-time-scale",
    "hooks:install": "git config core.hooksPath .githooks",
    "test:quick": "node test/quick-check.js",
    "test:baseline": "vitest test/ui.test.js",
    "test:baseline:verbose": "vitest test/ui.test.js --reporter=verbose",
    "test:baseline:headed": "cross-env HEADLESS=false vitest test/ui.test.js --reporter=verbose",
    "test:dev": "cross-env VITE_TEST_BASE_URL=http://localhost:8009 vitest test/ui.test.js --reporter=verbose",
    "test:prod": "cross-env VITE_TEST_BASE_URL=http://localhost:4173 vitest test/ui.test.js --reporter=verbose",
    "test:prod:missions": "cross-env PRODUCTION_SMOKE_BASE_URL=https://sankara.net/astro/lunar-missions vitest run test/production-mission-smoke.test.js --reporter=verbose",
    "test:custom": "vitest test/ui.test.js --reporter=verbose",
    "test:smoke": "npm run test:dev -- -t \"should load page and complete initial rendering in Earth mode\"",
    "test:basic": "npm run test:dev -- -t \"should load the page successfully|should be in Geocentric|should start in 3D mode\"",
    "test:ui": "npm run test:dev -- -t \"should have all critical UI elements|should open settings panel\"",
    "test:timeline": "npm run test:dev -- -t \"should make EBN#1 button|should make TLI button\"",
    "test:animation": "npm run test:dev -- -t \"should start animation|should pause animation\"",
    "test:views": "npm run test:dev -- -t \"should test Stellar Sky|should test Poles|should test XYZ Axes\"",
    "test:modes": "npm run test:dev -- -t \"should switch to 2D mode|should switch back to 3D mode\"",
    "test:headless": "cross-env HEADLESS=true npm run test:dev",
    "test:smoke:fast": "cross-env HEADLESS=true npm run test:smoke",
    "test:basic:fast": "cross-env HEADLESS=true npm run test:basic",
    "test:simple": "cross-env VITE_TEST_BASE_URL=http://localhost:7274 vitest test/ui.test.js --reporter=basic --no-coverage",
    "test:simple:smoke": "npm run test:simple -- -t \"should load page and complete initial rendering in Earth mode\"",
    "test:simple:modes": "npm run test:simple -- -t \"should switch to 2D mode|should switch back to 3D mode\"",
    "logs": "node scripts/view-test-logs.js",
    "logs:watch": "node scripts/view-test-logs.js && echo '\\n👀 Run this command again after tests to see updated logs'",
    "reproduce:zoom": "node test/reproduce-zoom-issue.js",
    "test:validated": "cross-env TEST_VALIDATION_MODE=validated VITE_TEST_BASE_URL=http://localhost:8009 vitest test/ui.test.js --reporter=basic --no-coverage",
    "test:unvalidated": "cross-env TEST_VALIDATION_MODE=unvalidated VITE_TEST_BASE_URL=http://localhost:8009 vitest test/ui.test.js --reporter=basic --no-coverage",
    "test:all": "cross-env TEST_VALIDATION_MODE=all VITE_TEST_BASE_URL=http://localhost:8009 vitest test/ui.test.js --reporter=basic --no-coverage",
    "validate:test": "node scripts/validate-test.js",
    "analyze:tests": "node scripts/analyze-test-categories.js",
    "bench:cheb-transport": "node scripts/bench-chebyshev-transport.js",
    "compress:cheb": "python scripts/compress-chebyshev-gzip.py",
    "audit:data-boundary": "python scripts/audit-data-repo-boundary.py --data-root ../moon-mission-data"
  },
  "keywords": [
    "chandrayaan3",
    "orbit",
    "animation",
    "isro",
    "space"
  ],
  "author": "Sankar",
  "license": "MIT",
  "devDependencies": {
    "@playwright/mcp": "^0.0.32",
    "@types/d3": "^7.4.3",
    "@types/jquery": "^3.5.32",
    "@types/node": "^24.2.1",
    "@types/three": "^0.179.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.0.0",
    "json5": "^2.2.3",
    "ssim.js": "^3.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "d3": "^7.9.0",
    "jszip": "^3.10.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.55.0-alpha-1752701791000",
    "pngjs": "^7.0.0",
    "swiper": "^11.2.10",
    "three": "^0.179.1"
  }
}
