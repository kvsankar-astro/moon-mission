{
  "name": "chandrayaan3-animation",
  "version": "1.0.0",
  "description": "3D animation of the ISRO Chandrayaan 3 mission orbit",
  "type": "module",
  "main": "chandrayaan3.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite --port 8000",
    "test": "node test/test-runner.js",
    "test:verbose": "node test/test-runner.js --verbose",
    "test:quick": "node test/quick-check.js",
    "test:playwright": "node test/playwright-mcp-test.js",
    "test:baseline": "echo 'Running baseline test...' && npm run test:verbose",
    "mcp:start": "npx @playwright/mcp@0.0.32 --port 8900",
    "mcp:test": "node -e \"import('./test/playwright-mcp-server-manager.js').then(m => m.ensureMCPServer().then(() => console.log('MCP server started')))\""
  },
  "keywords": [
    "chandrayaan3",
    "orbit",
    "animation",
    "isro",
    "space"
  ],
  "author": "Sankar",
  "license": "MIT",
  "devDependencies": {
    "@playwright/mcp": "^0.0.32",
    "vite": "^7.1.2"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "swiper": "^11.2.10",
    "three": "^0.179.1"
  }
}
