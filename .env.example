# sankara.net public asset bucket / R2 upload configuration.
# Copy to .env and fill secrets locally. Do not commit .env.

# Cloudflare account and optional bucket-admin API token.
# The API token is only needed for bucket/CORS/domain management via Wrangler.
CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
CLOUDFLARE_API_TOKEN_SANKARA_NET_ASSETS=<cloudflare-api-token-with-workers-r2-storage-edit>

# R2 bucket and public custom domain.
R2_ACCOUNT_ID_SANKARA_NET=<cloudflare-account-id>
R2_BUCKET_SANKARA_NET=sankara-net-assets
R2_S3_ENDPOINT_SANKARA_NET=https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN_SANKARA_NET=https://assets.sankara.net

# R2 S3-compatible upload credentials scoped to the bucket.
AWS_ACCESS_KEY_ID_SANKARA_NET=<r2-s3-access-key-id>
AWS_SECRET_ACCESS_KEY_SANKARA_NET=<r2-s3-secret-access-key>
AWS_REGION_SANKARA_NET=auto
AWS_DEFAULT_REGION_SANKARA_NET=auto
AWS_REQUEST_CHECKSUM_CALCULATION_SANKARA_NET=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION_SANKARA_NET=when_required

# Artemis II broadcast upload source/destination.
MOON_MISSION_ARTEMIS2_BROADCAST_LOCAL_DIR=/mnt/c/sankar/projects/moon-mission-data/assets/artemis2/media/streams/lunar-flyby/v1
MOON_MISSION_ARTEMIS2_BROADCAST_R2_PREFIX=moon-mission/artemis2/streams/lunar-flyby/v1/
MOON_MISSION_ARTEMIS2_BROADCAST_PUBLIC_URL=https://assets.sankara.net/moon-mission/artemis2/streams/lunar-flyby/v1/master.m3u8
