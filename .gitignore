# =========================
# Testing
# =========================
# Track baseline screenshots for visual regression testing
!test/screenshots/baseline/*.png
# But ignore temporary test output and current screenshots
test/screenshots/*current.png
test/screenshots/baseline/*-current.png
test/temp/
# Test run reports (timestamped logs and CSV files)
test/reports/

# Temporary test development files
test/baseline-ui-tests.js
test/find-ids.js
test/observe-plane-selection.js
test/plane-selection-expected-behaviors.md
test/plane-selection-observations.json
test/quick-interaction-test.js
test/timing-test.js
test/screenshots/clean-plane-*.png
test/screenshots/plane-*.png

# Windows temp files
nul

