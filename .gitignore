# =========================
# Project Specific
# =========================
# Generated orbit data (intermediate files from orbits.py)
# Only Chebyshev files (*-cheb.json) and metadata (*-meta.json) are committed
data-generated/

# Runtime Chebyshev artifacts are generated locally and published via
# moon-mission-data, not committed in moon-mission.
assets/*/data/*-cheb.json
assets/*/data/*-cheb.json.gz
assets/*/data/*-meta.json
assets/*/data/*-style.json

# Runtime media and vendored assets are staged locally from moon-mission-data.
assets/*/images/
images/*
!images/moon/
images/moon/*
!images/moon/ldem_16_gsfc.png
!images/moon/ldem_16_uint_quality.png
!images/moon/lroc_color_2025_4k_fast.jpg
!images/moon/lroc_color_2025_16k_quality.jpg
!images/social/
images/social/*
!images/social/mission-social.png
!images/social/index-social.png
!images/social/artemis2-social.png
third-party/

