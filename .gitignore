!assets/chandrayaan3/data/config.json
assets/chandrayaan3/archive/
# NISAR
assets/nisar/data/
# But track the main configuration file
!assets/nisar/data/config.json
assets/nisar/archive/

# Large models
assets/chandrayaan3/models/cy3.glb

# Archive folders
archive/

